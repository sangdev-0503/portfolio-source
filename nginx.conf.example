# Vi du cau hinh Nginx cho VPS
# Doi "yourdomain.com" va duong dan thu muc cho phu hop
# Sau khi sua, luu vao: /etc/nginx/sites-available/portfolio
# Roi chay:
#   sudo ln -s /etc/nginx/sites-available/portfolio /etc/nginx/sites-enabled/
#   sudo nginx -t
#   sudo systemctl reload nginx

server {
    listen 80;
    listen [::]:80;
    server_name yourdomain.com www.yourdomain.com;

    root /var/www/portfolio;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location ~* \.(?:css|js|jpg|jpeg|png|svg|woff2?)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    gzip on;
    gzip_types text/css application/javascript image/svg+xml;
}

# Sau khi tro DNS ve server va cai xong, chay them de co HTTPS mien phi:
#   sudo apt install certbot python3-certbot-nginx
#   sudo certbot --nginx -d yourdomain.com -d www.yourdomain.com
